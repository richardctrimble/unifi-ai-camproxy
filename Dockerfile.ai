# ── unifi-ai-camproxy: local AI image (:ai) ───────────────────────────────────
#
# Spoofs RTSP cameras into UniFi Protect as AI cameras. Runs YOLOv8
# person/vehicle detection locally. Virtual line-crossing zones can be
# drawn in the web UI (Lines tab).
#
# Hardware: CPU + Intel OpenVINO (iGPU / dGPU / NPU via /dev/dri passthrough).
# For NVIDIA CUDA use Dockerfile.ai-cuda.
#
# Final image size: ~1.5 GB.

# ── Stage 1: build unifi-cam-proxy (protocol layer) ──────────────────────────
FROM python:3.11-slim AS proxy-builder

WORKDIR /build
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Pin upstream to a known-good commit so rebuilds are reproducible.
# Bump this after testing against a newer commit — don't track HEAD.
ARG UNIFI_CAM_PROXY_REF=cc6d3fc7cdae9f1dfce575627089632aec696403
RUN git clone https://github.com/keshavdv/unifi-cam-proxy.git \
    && git -C unifi-cam-proxy checkout "$UNIFI_CAM_PROXY_REF"

# ── Stage 2: final image ──────────────────────────────────────────────────────
FROM python:3.11-slim

LABEL maintainer="unifi-ai-camproxy"
LABEL description="UniFi AI camera proxy — local inference (CPU + Intel OpenVINO)"

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    netcat-traditional \
    openssl \
    libglib2.0-0 \
    libgl1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=proxy-builder /build/unifi-cam-proxy /app/unifi-cam-proxy
RUN for file in requirements.txt setup.cfg setup.py; do \
        path="/app/unifi-cam-proxy/$file"; \
        if [ -f "$path" ]; then sed -i '/pyunifiprotect/d' "$path"; fi; \
    done
RUN pip install --no-cache-dir -e /app/unifi-cam-proxy

# CPU PyTorch wheel — small (~800MB), satisfies ultralytics' import.
RUN pip install --no-cache-dir \
      --index-url https://download.pytorch.org/whl/cpu \
      torch torchvision

# Intel compute runtime. intel-opencl-icd from Debian bookworm non-free-firmware
# covers Gen8–Gen12 iGPUs (everything commonly in TrueNAS / mini-PC hardware).
# libze1 is the Level Zero loader; OpenVINO falls back to OpenCL when L0 GPU
# plugin isn't available, which is fine for Gen9–Gen11.
RUN echo "deb http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware" \
        > /etc/apt/sources.list.d/nonfree.list \
     && echo "deb http://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware" \
        >> /etc/apt/sources.list.d/nonfree.list \
     && echo "deb http://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware" \
        >> /etc/apt/sources.list.d/nonfree.list \
     && apt-get update && apt-get install -y --no-install-recommends \
        intel-opencl-icd \
        ocl-icd-libopencl1 \
        libze1 \
     && (apt-get install -y --no-install-recommends intel-level-zero-gpu \
         || echo "WARN: intel-level-zero-gpu not available — OpenVINO will use OpenCL only") \
     && rm -rf /var/lib/apt/lists/* \
     && pip install --no-cache-dir "openvino>=2024.0.0"

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY docker-entrypoint.py /app/
COPY src/ /app/src/

ARG GIT_SHA=unknown
ARG GIT_REF=unknown
ARG BUILD_TIME=unknown
ENV APP_GIT_SHA=$GIT_SHA
ENV APP_GIT_REF=$GIT_REF
ENV APP_BUILD_TIME=$BUILD_TIME
ENV APP_IMAGE_VARIANT=ai
RUN printf '%s\n' \
      "git_sha: ${GIT_SHA}" \
      "git_ref: ${GIT_REF}" \
      "build_time: ${BUILD_TIME}" \
      "image_variant: ai" \
      > /app/BUILD_INFO

# Pre-download YOLOv8n so first run doesn't stall on model fetch
RUN python -c "from ultralytics import YOLO; YOLO('yolov8n.pt')"

VOLUME ["/config"]
EXPOSE 8091

WORKDIR /app/src

ENTRYPOINT ["python", "/app/docker-entrypoint.py"]
